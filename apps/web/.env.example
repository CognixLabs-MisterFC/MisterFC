# MisterFC — env vars de apps/web
#
# Copia este archivo a `apps/web/.env.local` y rellena los valores reales.
# `.env.local` está en .gitignore — nunca se commitea.

# ─── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Sentry ────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN: DSN del proyecto en sentry.io. Para MisterFC apunta
# al proyecto cuyo slug es `javascript-nextjs` (project id 4511458093432912).
# Sin esta var, el SDK NO inicializa y los Sentry.captureException son no-ops.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=mister-fc
# SENTRY_PROJECT: slug real del proyecto en sentry.io. Usado por
# `withSentryConfig` solo para upload de source maps. NO afecta a la captura
# de eventos (esa la controla NEXT_PUBLIC_SENTRY_DSN). El slug correcto en
# Cognix Labs es `javascript-nextjs` (no `misterfc-web`).
SENTRY_PROJECT=javascript-nextjs
SENTRY_AUTH_TOKEN=
