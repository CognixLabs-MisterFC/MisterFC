# MisterFC — direnv config
#
# Activar con `direnv allow` la primera vez que se hace pull.
# Carga la cuenta GitHub correcta y la identidad git para este repo,
# y expone las variables de entorno de .env.local en la shell.

# Cambia a la cuenta GitHub correcta automáticamente
if command -v gh >/dev/null; then
  gh auth switch --user CognixLabs-Nido 2>/dev/null || true
fi

# Identidad git per-repo (redundante con `git config --local` pero seguro)
export GIT_AUTHOR_NAME="Iker Milla"
export GIT_AUTHOR_EMAIL="jovimib@gmail.com"
export GIT_COMMITTER_NAME="Iker Milla"
export GIT_COMMITTER_EMAIL="jovimib@gmail.com"

# pnpm en PATH (por si la shell no lo trae)
export PNPM_HOME="${PNPM_HOME:-$HOME/.local/share/pnpm}"
case ":$PATH:" in
  *":$PNPM_HOME/bin:"*) ;;
  *) export PATH="$PNPM_HOME/bin:$PATH" ;;
esac

# Carga .env.local si existe (el dotenv builtin de direnv)
[ -f .env.local ] && dotenv .env.local
[ -f apps/web/.env.local ] && dotenv apps/web/.env.local
