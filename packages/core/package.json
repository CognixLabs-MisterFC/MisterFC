{
  "name": "@misterfc/core",
  "version": "0.0.0",
  "private": true,
  "description": "Lógica compartida de MisterFC (TypeScript, Zod, Supabase). Agnóstica de framework — reusable desde apps/web (Ola 1) y apps/native (Ola 2).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./supabase/browser": {
      "types": "./src/supabase/client-browser.ts",
      "import": "./src/supabase/client-browser.ts"
    },
    "./supabase/server": {
      "types": "./src/supabase/client-server.ts",
      "import": "./src/supabase/client-server.ts"
    },
    "./schemas": {
      "types": "./src/schemas/index.ts",
      "import": "./src/schemas/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "import": "./src/types/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings=0",
    "clean": "rm -rf .turbo dist"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "eslint": "^9.16.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.0"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "zod": "^4.4.3"
  }
}
